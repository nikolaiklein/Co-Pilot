# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ALLOWED_USERS=292628110  # comma-separated Telegram user IDs (empty = allow all)

# AI Providers (at least one required)
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# Default AI model (format: provider/model)
# Examples: gemini/gemini-2.5-flash, anthropic/claude-sonnet-4-20250514, openai/gpt-4o
DEFAULT_MODEL=gemini/gemini-2.5-flash

# Google Cloud / Firebase
# For local dev: path to service account JSON key
# In Cloud Run: leave empty, uses ADC automatically
GOOGLE_APPLICATION_CREDENTIALS=

# Server
PORT=8080
LOG_LEVEL=INFO
